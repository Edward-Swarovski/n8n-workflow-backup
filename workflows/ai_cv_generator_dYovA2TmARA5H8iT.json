      {
        "parameters": {
          "jsCode": "const content = $json.text || $json.output || $json.response || $json.message || $json.data?.text || \"{}\";\nlet parsed = {};\ntry { parsed = JSON.parse(content); } catch (e) { parsed = {}; }\nreturn [{ json: { ...$json, analysis: parsed } }];"
        },
        "id": "2cba9114-7ebe-4cc5-8065-10f7f3189157",
        "name": "Parse Analysis",
