      {
        "parameters": {
          "jsCode": "const jd = $json.clean_job_description_plain || '';\nconst prompt = `You are an expert recruiter and ATS optimizer.\\n\\nExtract key requirements from the JOB DESCRIPTION below. Use the content provided and do not invent a different job.\\n\\nReturn STRICT JSON with keys: job_title, company, skills (array), technologies (array), seniority, industry, keywords (array). No markdown, no code fences.\\n\\nJOB DESCRIPTION (verbatim):\\n\\\"\\\"\\\"\\n${jd}\\n\\\"\\\"\\\"`;\nreturn [{ ...$json, analyse_prompt: prompt }];"
        },
        "id": "0e441857-a7df-456e-bd86-561df808ec8a",
        "name": "Build Analyse Prompt",
