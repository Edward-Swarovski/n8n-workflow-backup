      {
        "parameters": {
          "promptType": "define",
          "text": "You are an expert recruiter and ATS optimizer.\n\nExtract key requirements from this job description. Return STRICT JSON with keys: job_title, company, skills (array), technologies (array), seniority, industry, keywords (array). No markdown, no code fences.\n\nJOB DESCRIPTION:\n{{$node[\"Merge JD\"].json.clean_job_description}}"
        },
        "id": "95d67867-dac4-4fff-a2dd-52f3b2ea7f7e",
        "name": "Analyse JD",
        "type": "@n8n/n8n-nodes-langchain.chainLlm",
        "typeVersion": 1.6,
        "position": [
          26560,
          2224
        ]
      },
      {
        "parameters": {
          "jsCode": "const content = $json.text || $json.output || $json.response || $json.message || $json.data?.text || \"{}\";\nlet parsed = {};\ntry { parsed = JSON.parse(content); } catch (e) { parsed = {}; }\nreturn [{...$json, analysis: parsed}];"
        },
        "id": "27b36c2b-d147-4d1f-883c-d514f39bfd2d",
        "name": "Parse Analysis",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          26848,
          2224
        ]
      },
      {
        "parameters": {
          "promptType": "define",
          "text": "You are a senior CV writer.\n\nGenerate a tailored CV in Markdown. Use ATS-friendly formatting with headings: Name, Professional Summary, Key Skills, Professional Experience, Education, Certifications. Use concise bullet points.\n\nJOB DESCRIPTION:\n{{$node[\"Merge JD\"].json.clean_job_description}}\n\nJOB REQUIREMENTS JSON:\n{{$node[\"Parse Analysis\"].json.analysis}}\n\nCANDIDATE KNOWLEDGE BASE:\n{{$node[\"Load KB\"].json.stdout}}"
        },
        "id": "5a892b77-aff6-4f3b-827b-33d92328af99",
        "name": "Generate CV",
        "type": "@n8n/n8n-nodes-langchain.chainLlm",
        "typeVersion": 1.6,
        "position": [
          26992,
          2224
        ]
      },
      {
        "parameters": {
          "promptType": "define",
          "text": "You are a strict CV editor.\n\nReview and improve the CV for grammar, clarity, missing keywords, and ATS compatibility. Return ONLY the improved CV in Markdown.\n\nJOB REQUIREMENTS JSON:\n{{$node[\"Parse Analysis\"].json.analysis}}\n\nCV DRAFT:\n{{$node[\"Generate CV\"].json.text || $node[\"Generate CV\"].json.output || $node[\"Generate CV\"].json.response || $node[\"Generate CV\"].json.message}}"
        },
        "id": "6c064675-0c17-4e21-97da-81e4b73c5b4d",
        "name": "Review CV",
        "type": "@n8n/n8n-nodes-langchain.chainLlm",
        "typeVersion": 1.6,
        "position": [
          27216,
          2224
        ]
      },
      {
        "parameters": {
          "promptType": "define",
          "text": "You are a professional career coach.\n\nWrite a professional cover letter (150-200 words) matching the job requirements. Return only Markdown.\n\nJOB REQUIREMENTS JSON:\n{{$node[\"Parse Analysis\"].json.analysis}}\n\nFINAL CV:\n{{$node[\"Review CV\"].json.text || $node[\"Review CV\"].json.output || $node[\"Review CV\"].json.response || $node[\"Review CV\"].json.message}}"
        },
        "id": "aaa6b840-c35b-4518-8323-7abc9fe011a7",
        "name": "Generate Cover Letter",
        "type": "@n8n/n8n-nodes-langchain.chainLlm",
        "typeVersion": 1.6,
        "position": [
          27440,
          2224
        ]
      },
      {
        "parameters": {
          "jsCode": "function pad(n){return n.toString().padStart(2,'0');}\nconst now = new Date();\nconst ts = `${now.getFullYear()}${pad(now.getMonth()+1)}${pad(now.getDate())}_${pad(now.getHours())}${pad(now.getMinutes())}${pad(now.getSeconds())}`;\nconst title = ($node[\"Parse Analysis\"].json.analysis?.job_title || 'job').toString();\nconst company = ($node[\"Parse Analysis\"].json.analysis?.company || 'company').toString();\nconst safe = s => s.replace(/[^a-zA-Z0-9]+/g,'_').replace(/^_+|_+$/g,'').toLowerCase();\nconst base = `${ts}__${safe(title)}__${safe(company)}`;\nconst webhookBase = ($env.WEBHOOK_URL || '').replace(/\\/+$/,'') + '/';\nconst token = $env.CV_DOWNLOAD_TOKEN || '';\nconst finalCv = $node[\"Review CV\"].json.text || $node[\"Review CV\"].json.output || $node[\"Review CV\"].json.response || $node[\"Review CV\"].json.message || '';\nconst cover = $node[\"Generate Cover Letter\"].json.text || $node[\"Generate Cover Letter\"].json.output || $node[\"Generate Cover Letter\"].json.response || $node[\"Generate Cover Letter\"].json.message || '';\nreturn [{\n  ...$json,\n  ts,\n  cv_filename: `${base}.docx`,\n  cover_filename: `${base}_cover.docx`,\n  cv_markdown: finalCv,\n  cover_markdown: cover,\n  cv_download_url: `${webhookBase}webhook/cv-download?file=${encodeURIComponent(`${base}.docx`)}&token=${token}`,\n  cover_download_url: `${webhookBase}webhook/cv-download?file=${encodeURIComponent(`${base}_cover.docx`)}&token=${token}`\n}];"
        },
