      "parameters": {
        "jsCode": "const blocks = $json.text || $json.data || $json.body || '';\nconst arr = Array.isArray(blocks) ? blocks : [blocks];\nlet posting = null;\nfor (const item of arr) {\n  try {\n    const obj = JSON.parse(item);\n    if (obj['@type'] === 'JobPosting') {\n      posting = obj;\n      break;\n    }\n  } catch (e) {}\n}\nreturn [{\n  clean_job_description: posting?.description || ''\n}];"
      },
