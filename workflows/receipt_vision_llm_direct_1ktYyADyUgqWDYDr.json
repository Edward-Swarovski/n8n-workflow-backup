    {
      "parameters": {
        "jsCode": "const raw = $json.choices[0].message.content;\n\n// Strip markdown fences if model adds them despite instructions\nconst cleaned = raw\n  .replace(/^```json\\s*/i, '')\n  .replace(/^```\\s*/i, '')\n  .replace(/```\\s*$/i, '')\n  .trim();\n\nlet parsed;\ntry {\n  parsed = JSON.parse(cleaned);\n} catch (e) {\n  throw new Error('LLM did not return valid JSON. Raw output: ' + raw.substring(0, 300));\n}\n\nif (!parsed.items || !Array.isArray(parsed.items) || parsed.items.length === 0) {\n  throw new Error('No items found in parsed receipt');\n}\n\nconst executionId = $execution.id;\nconst receiptMeta = {\n  receipt_id: executionId,\n  store_name: parsed.store_name ?? null,\n  store_branch: parsed.store_branch ?? null,\n  store_address: parsed.store_address ?? null,\n  store_postcode: parsed.store_postcode ?? null,\n  receipt_date: parsed.receipt_date ?? null,\n  receipt_time: parsed.receipt_time ?? null,\n  currency: parsed.currency ?? 'GBP',\n  subtotal: parsed.subtotal ?? null,\n  discount_total: parsed.discount_total ?? null,\n  tax_amount: parsed.tax_amount ?? null,\n  total_amount: parsed.total_amount ?? null,\n  payment_method: parsed.payment_method ?? null,\n  last4_card_digits: parsed.last4_card_digits ?? null,\n  loyalty_programme: parsed.loyalty_programme ?? null,\n  source_image_url: $('Webhook').item.json.body.attachments[0].url,\n  discord_user: $('Webhook').item.json.body.author.username,\n  created_at: new Date().toISOString(),\n};\n\n// Return one n8n item per line item, with receipt metadata merged in\nreturn parsed.items.map(item => ({\n  json: {\n    ...receiptMeta,\n    line_number: item.line_number,\n    product_name: item.product_name,\n    normalised_name: item.normalised_name,\n    category: item.category,\n    quantity: item.quantity,\n    unit: item.unit ?? null,\n    unit_price: item.unit_price ?? null,\n    line_total: item.line_total ?? null,\n    is_discount_line: item.is_discount_line ?? false,\n    discount_amount: item.discount_amount ?? null,\n    is_taxable: item.is_taxable ?? false,\n    tax_rate_percent: item.tax_rate_percent ?? 0,\n    brand: item.brand ?? null,\n    sku_or_barcode: item.sku_or_barcode ?? null,\n  }\n}));\n"
      },
