    {
      "parameters": {
        "jsCode": "const receipt = $('Filter Empty Rows').first().json;\nconst receiptDate = (receipt.receipt_date ?? '').toString().trim();\nconst receiptTime = (receipt.receipt_time ?? '').toString().trim();\nconst storeName = (receipt.store_name ?? '').toString().trim().toLowerCase();\nconst storeBranch = (receipt.store_branch ?? '').toString().trim().toLowerCase();\nconst discordUser = (receipt.discord_user ?? '').toString().trim().toLowerCase();\n\nconst existingRows = $input.all();\nconst duplicate = existingRows.find(row => {\n  return (\n    (row.json.receipt_date ?? '').toString().trim() === receiptDate &&\n    (row.json.receipt_time ?? '').toString().trim() === receiptTime &&\n    (row.json.store_name ?? '').toString().trim().toLowerCase() === storeName &&\n    (row.json.store_branch ?? '').toString().trim().toLowerCase() === storeBranch &&\n    (row.json.discord_user ?? '').toString().trim().toLowerCase() === discordUser\n  );\n});\n\nreturn $('Filter Empty Rows').all().map(item => ({\n  json: {\n    ...item.json,\n    _is_duplicate: !!duplicate,\n  }\n}));\n"
      },
